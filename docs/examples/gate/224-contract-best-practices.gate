        "kind": "context-precondition",
        "flowName": "getPatientProfile",
        "verified": "static",
        "description": "contract.context requires [actor, trace_id] and contract.rules requires 'actor before database.read'; both context fields are read before PatientsDB.findById"
      },
      {
        "kind": "privacy-egress",
        "flowName": "getPatientProfile",
        "verified": "static",
        "description": "contract.privacy denies protected Email to response and requires redaction before audit.write; response exposes only {patientId, name, dateOfBirth} and denies {email, nhsNumber} — no denied field appears in Response.ok"
      },
      {
        "kind": "redaction",
        "flowName": "getPatientProfile",
